<Application
    x:Class="AssistiveTouch.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <ResourceDictionary Source="ms-appx:///Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- DataTemplate for app rules list -->
            <DataTemplate x:Key="RuleItemTemplate">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}"/>
                    <TextBlock VerticalAlignment="Center" Opacity="0.5" FontSize="11"
                               Text="{Binding Enabled}"/>
                </StackPanel>
            </DataTemplate>

            <!-- DataTemplate for widget group list -->
            <DataTemplate x:Key="WidgetItemTemplate">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="{Binding Icon}"/>
                    <TextBlock VerticalAlignment="Center" Text="{Binding Label}"/>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
