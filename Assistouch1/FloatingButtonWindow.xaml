<Window
    x:Class="AssistiveTouch.FloatingButtonWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid"
          Background="#01000000"
          PointerPressed="OnPointerPressed"
          PointerMoved="OnPointerMoved"
          PointerReleased="OnPointerReleased"
          PointerCaptureLost="OnPointerCaptureLost">

        <!-- Pure SystemBackdrop (Acrylic/Mica) shows through — no XAML background. -->
        <Border x:Name="ButtonCard"
                CornerRadius="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                Margin="0">

            <!-- Four dots 2×2, centred -->
            <Grid IsHitTestVisible="False"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="26" Height="26">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Row="0" Grid.Column="0" Width="7" Height="7"
                         Fill="{ThemeResource TextFillColorPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Grid.Row="0" Grid.Column="1" Width="7" Height="7"
                         Fill="{ThemeResource TextFillColorPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Grid.Row="1" Grid.Column="0" Width="7" Height="7"
                         Fill="{ThemeResource TextFillColorPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Grid.Row="1" Grid.Column="1" Width="7" Height="7"
                         Fill="{ThemeResource TextFillColorPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
