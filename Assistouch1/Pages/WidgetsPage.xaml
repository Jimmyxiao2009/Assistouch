<Page
    x:Class="AssistiveTouch.Pages.WidgetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left header ── -->
        <Grid Grid.Row="0" Grid.Column="0"
              Margin="24,28,0,12">
            <TextBlock Text="小工具"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button x:Name="AddWidgetBtn"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="32" Height="32"
                    Padding="0"
                    CornerRadius="16"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="AddWidgetBtn_Click">
                <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>
        </Grid>

        <!-- ── Widget list ── -->
        <ListView x:Name="WidgetList"
                  Grid.Row="1" Grid.Column="0"
                  Margin="24,0,0,24"
                  SelectionMode="Single"
                  SelectionChanged="WidgetList_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,3,0,0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="14"
                                      Glyph="{Binding Icon}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Label}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Detail pane ── -->
        <ScrollViewer Grid.Row="1" Grid.Column="2"
                      Margin="0,0,24,24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="DetailPanel" Spacing="16"/>
        </ScrollViewer>
    </Grid>
</Page>
