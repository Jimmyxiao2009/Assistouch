<Page
    x:Class="AssistiveTouch.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <!-- Shared card container style -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- Thin divider inside a card -->
        <Style x:Key="CardDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            <Setter Property="Margin" Value="-16,0"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Margin="40,32,40,40">

            <!-- ── Page title ── -->
            <TextBlock Text="常规设置"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       FontWeight="SemiBold"/>

            <!-- ══════════ 外观 ══════════ -->
            <StackPanel Spacing="4">
                <TextBlock Text="外观"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="2,0,0,6"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="0">

                        <!-- Backdrop (Settings window) -->
                        <Grid Padding="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="设置窗口背景效果"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock Text="云母 / 亚克力效果需要 Windows 11"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"/>
                            </StackPanel>
                            <ComboBox x:Name="BackdropCombo" Grid.Column="2"
                                      MinWidth="160" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Style="{StaticResource CardDividerStyle}"/>

                        <!-- Theme -->
                        <Grid Padding="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色主题"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="ThemeCombo" Grid.Column="2"
                                      MinWidth="160" VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══════════ 浮动按钮 ══════════ -->
            <StackPanel Spacing="4">
                <TextBlock Text="浮动按钮"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="2,0,0,6"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="0">

                        <!-- Button size -->
                        <StackPanel Padding="0,10,0,10" Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="按钮尺寸"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="SizeLabel" Grid.Column="1"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.6" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="SizeSlider"
                                    Minimum="36" Maximum="80" StepFrequency="2"
                                    TickFrequency="8" TickPlacement="Outside"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <Border Style="{StaticResource CardDividerStyle}"/>

                        <!-- Button backdrop -->
                        <Grid Padding="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="按钮与菜单背景效果"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock Text="亚克力 / 云母效果需要 Windows 11"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"/>
                            </StackPanel>
                            <ComboBox x:Name="ButtonBackdropCombo" Grid.Column="2"
                                      MinWidth="160" VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══════════ 行为 ══════════ -->
            <StackPanel Spacing="4">
                <TextBlock Text="行为"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="2,0,0,6"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid Padding="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="前台窗口检测间隔"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock Text="间隔越短越灵敏，但会稍微占用更多 CPU"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.55"/>
                        </StackPanel>
                        <ComboBox x:Name="PollCombo" Grid.Column="2"
                                  MinWidth="160" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ══════════ 系统 ══════════ -->
            <StackPanel Spacing="4">
                <TextBlock Text="系统"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="2,0,0,6"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="0">

                        <!-- Startup toggle -->
                        <Grid Padding="0,6,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="开机自动启动"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock Text="随 Windows 登录自动运行"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="StartupToggle" Grid.Column="2"
                                          VerticalAlignment="Center"
                                          OnContent="" OffContent="" Margin="0"/>
                        </Grid>

                        <Border Style="{StaticResource CardDividerStyle}"/>

                        <!-- Config folder -->
                        <Grid Padding="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="配置文件位置"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock x:Name="CfgPathText"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.5" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Name="OpenCfgBtn" Grid.Column="2"
                                    Content="打开文件夹"
                                    VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══════════ 备份与导入 ══════════ -->
            <StackPanel Spacing="4">
                <TextBlock Text="备份与导入"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="2,0,0,6"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="0">

                        <!-- Export -->
                        <Grid Padding="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="导出配置"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock Text="将当前配置保存为 JSON 文件"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"/>
                            </StackPanel>
                            <Button x:Name="ExportBtn" Grid.Column="2"
                                    Content="导出…"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Border Style="{StaticResource CardDividerStyle}"/>

                        <!-- Import -->
                        <Grid Padding="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="导入配置"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock Text="从 JSON 文件还原配置（将覆盖当前设置）"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"/>
                            </StackPanel>
                            <Button x:Name="ImportBtn" Grid.Column="2"
                                    Content="导入…"
                                    VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══════════ 关于 ══════════ -->
            <StackPanel Spacing="4">
                <TextBlock Text="关于"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="2,0,0,6"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid Padding="0,6,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE7C8;" FontFamily="Segoe MDL2 Assets"
                                      FontSize="24" Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
                            <TextBlock x:Name="AboutVersionText"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="为大屏教学场景设计，支持自定义规则、快捷操作与小工具。"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.6" TextWrapping="Wrap"/>
                            <TextBlock Text="作者 / 发布者：1b4e28ba-2fa1-5f3d-85e5-740e1a5a8a1f"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.45" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
