<Page
    x:Class="AssistiveTouch.Pages.PinnedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="40,32,40,16">
            <TextBlock Text="固定操作"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       FontWeight="SemiBold"/>
            <TextBlock Text="这些操作始终显示在菜单中，不受前台应用影响。"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Opacity="0.6"/>
        </StackPanel>

        <!-- ── Action list (imperative) ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ItemPanel" Spacing="4" Margin="40,0,40,0"/>
        </ScrollViewer>

        <!-- ── Footer ── -->
        <Border Grid.Row="2"
                Margin="40,12,40,32"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12,10">
            <Grid>
                <Button x:Name="AddBtn"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddBtn_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        <TextBlock Text="添加操作"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="拖动左侧 ☰ 可调整顺序"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.4"/>
            </Grid>
        </Border>
    </Grid>
</Page>
