<Page
    x:Class="AssistiveTouch.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <Style x:Key="NavCardStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="40,32,40,40">

            <!-- ── App banner ── -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="80" Height="80"
                        CornerRadius="18"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xE7C8;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="40"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="AssisTouch"
                               Style="{StaticResource TitleLargeTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="VersionText"
                               Opacity="0.6"
                               Style="{StaticResource BodyTextBlockStyle}"/>
                    <TextBlock Text="为大屏教学场景设计 · 适用于 Windows"
                               Opacity="0.45"
                               FontSize="12"/>
                </StackPanel>
            </Grid>

            <!-- ── Section header ── -->
            <TextBlock Text="快速导航"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="2,4,0,0"/>

            <!-- Pinned -->
            <Button Style="{StaticResource NavCardStyle}" Click="GoPinnedBtn_Click">
                <Grid Padding="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <FontIcon Glyph="&#xE718;" FontFamily="Segoe MDL2 Assets"
                                  FontSize="18" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="固定操作" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="管理始终显示在菜单中的操作项"
                                   FontSize="12" Opacity="0.55"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <FontIcon Grid.Column="3" Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                              FontSize="12" Opacity="0.4" VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <!-- Rules -->
            <Button Style="{StaticResource NavCardStyle}" Click="GoRulesBtn_Click">
                <Grid Padding="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                            Background="#107C10">
                        <FontIcon Glyph="&#xE7C1;" FontFamily="Segoe MDL2 Assets"
                                  FontSize="18" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="应用规则" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="为特定程序配置专属菜单操作"
                                   FontSize="12" Opacity="0.55"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <FontIcon Grid.Column="3" Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                              FontSize="12" Opacity="0.4" VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <!-- Widgets -->
            <Button Style="{StaticResource NavCardStyle}" Click="GoWidgetsBtn_Click">
                <Grid Padding="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                            Background="#7A7574">
                        <FontIcon Glyph="&#xE74C;" FontFamily="Segoe MDL2 Assets"
                                  FontSize="18" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="小工具" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="在菜单中嵌入实时信息小组件"
                                   FontSize="12" Opacity="0.55"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <FontIcon Grid.Column="3" Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                              FontSize="12" Opacity="0.4" VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <!-- General -->
            <Button Style="{StaticResource NavCardStyle}" Click="GoGeneralBtn_Click">
                <Grid Padding="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                            Background="#605E5C">
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                  FontSize="18" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="常规设置" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="外观、主题、按钮尺寸与系统选项"
                                   FontSize="12" Opacity="0.55"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <FontIcon Grid.Column="3" Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                              FontSize="12" Opacity="0.4" VerticalAlignment="Center"/>
                </Grid>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Page>
